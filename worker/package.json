{
	"name": "ipintel",
	"version": "1.0.0",
	"description": "IP threat-intel insight lookups on a Cloudflare Worker",
	"license": "Apache-2.0",
	"type": "module",
	"scripts": {
		"lookup": "tsx scripts/lookup.ts",
