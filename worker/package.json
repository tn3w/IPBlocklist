		"dev": "wrangler dev --config ../wrangler.jsonc"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260606.1",
		"@types/node": "^25.9.2",
		"prettier": "^3.8.3",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"wrangler": "^4.98.0"
	}
}
